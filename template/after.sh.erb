# Wait for the llama.cpp server to start
echo "Waiting for gradio server to open port ${port}..."
if wait_until_port_used "${host}:${port}" 600; then
  echo "Discovered gradio server listening on port ${port}!"
else
  echo "Timed out waiting for gradio server to open port ${port}!"
  clean_up 1
fi
sleep 2
