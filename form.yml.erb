<%
extend AccountCache
useraccounts = dynamic_accounts
%>
---
cluster:
  - "deac"
form:
  - version
  - enable_extra_modules
  - extra_modules
  - working_dir
  - accounts
  - queues
  - bc_num_slots
  - bc_num_hours
  - num_cores
  - memory
  - node_type
  - num_gpus
  - enable_audiocraft_path
  - audiocraft_path
  - bc_email_on_started
attributes:
  version: ""
  enable_extra_modules:
    label: "Enable Extra Environment Modules"
    widget: 'check_box'
    html_options:
      data:
        hide-extra-modules-when-un-checked: true
  extra_modules:
    label: "Additional Environment Modules"
    widget: "text_field"
    value: ""
    help: |
      Any additional modules that you would like to load. Separate by spaces, just like you would in a normal *module load* command.
  working_dir:
    label: "Working Directory"
    widget: "path_selector"
    data-target-file-type: dirs  # Valid values are: files, dirs, or both
    readonly: false
    help: |
      Select your project directory; defaults to $HOME.
  auto_accounts:
    label: "Slurm Account"
    help: |
      The Slurm account to be used for your job submission.
  accounts:
    label: "Slurm Account"
    widget: "select"
    options:
      <%- useraccounts.each do |g| -%>
      - [ "<%= g.first.downcase %>", data-set-queues: "ondemand", ]
      <%- end -%>
    help: |
      The Slurm account to be used for your job submission.
  bc_queue: "ondemand"
  auto_queues:
    label: "Slurm Partition"
    value: "ondemand"
    help: |
        - Default partition is **ondemand**
  queues:
    label: "Slurm Partition"
    widget: select
    value: "ondemand"
    options:
      - [ "ondemand" ]
    help: |
        - **Default: ondemand**
  bc_num_slots: 1
  bc_num_hours:
    min: 1
    value: 1
    step: 1
    help: |
      Number of hours being requested.
  num_cores:
    label: "Number of Cores"
    widget: "number_field"
    value: 1
    help: |
      Number of cores beings requested; leave blank to request all cores on a compute node.
    min: 1
    step: 1
  memory:
    label: "Memory (GB)"
    widget: "number_field"
    value: 8
    help: |
      Amount of RAM being requested in GB.
    min: 1
    step: 1
  num_gpus:
    label: "Number of GPUs"
    widget: "number_field"
    value: 0
    help: |
      Number of GPUs requested. Only available with **GPU** node type.
    min: 0
    step: 1
  node_type:
      widget: select
      label: "Node type"
      help: |
        Request either **CPU** or **GPU** compute nodes. 
      options:
        - [
            "CPU", "cpu",
            data-max-num-cores: 64,
            data-max-num-gpus: 0,
            data-min-num-gpus: 0,
            data-max-memory: 2250,
            data-option-for-queues-ondemand: true,
            data-set-num-gpus: 0,
            data-hide-num-gpus: true,
          ]
        - [
            "GPU", "gpu",
            data-max-num-cores: 64,
            data-max-num-gpus: 4,
            data-min-num-gpus: 1,
            data-max-memory: 1000,
            data-option-for-queues-ondemand: true,
            data-set-num-gpus: 1,
          ]
  enable_audiocraft_path:
    label: |
      ADVANCED: Custom AUDIOCRAFT_CACHE_DIR
    widget: 'check_box'
    html_options:
      data:
        hide-audiocraft_path-when-un-checked: true
  audiocraft_path:
    widget: "text_field"
    label: "Define the AUDIOCRAFT_CACHE_DIR environment variable for your AudioCraft app."
    value: ""
    help: |
      `AUDIOCRAFT_CACHE_DIR` is the path to a config directory where AudioCraft will download models from HuggingFace and store for music generation.
